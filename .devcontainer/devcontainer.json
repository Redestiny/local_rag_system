{
  "name": "RAG System Full-Stack Dev Env",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "docker-compose.dev.yml"
  ],
  "service": "backend",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "overrideCommand": true,
  "remoteUser": "root",

  // 转发后端和前端的端口
  "forwardPorts": [8000, 3000],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.linting.enabled": true
      }
    }
  },

  // 安装前端依赖
  "postCreateCommand": {
    "frontend": "npm install --prefix /workspaces/${localWorkspaceFolderBasename}/frontend"
  }
}